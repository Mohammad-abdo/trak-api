# ─── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────
DATABASE_URL=mysql://root:@localhost:3306/driverproject

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# ─── CORS ────────────────────────────────────────────────
CORS_ORIGIN="*"
FRONTEND_URL=http://localhost:3000

# ─── Proxy & request logging (optional) ──────────────────
# TRUST_PROXY=1
# HTTP_ACCESS_LOG=1
# SECURITY_AUDIT_LOG_ENABLED=1
# AUDIT_LOG_RETENTION_DAYS=90

# ═══════════════════════════════════════════════════════════
# MAPS — server-side (geocoding, directions, zone checks)
# ═══════════════════════════════════════════════════════════
GOOGLE_MAPS_API_KEY=
# Optional alternatives / extras
# MAPBOX_ACCESS_TOKEN=
# HERE_API_KEY=

# ═══════════════════════════════════════════════════════════
# OTP / SMS — used when sending verification codes
# (wire your provider in utils/smsService.js if needed)
# ═══════════════════════════════════════════════════════════
SMS_DISABLED=true
TEST_OTP=123456

# Generic provider hook (fill if your gateway uses one key)
OTP_SMS_API_KEY=
OTP_SMS_API_URL=
OTP_SMS_SENDER_ID=

# Twilio (example)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_MESSAGING_SERVICE_SID=
# TWILIO_PHONE_NUMBER=

# AWS SNS (example)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=

# ═══════════════════════════════════════════════════════════
# PAYMENT — gateways (secrets stay on server only)
# ═══════════════════════════════════════════════════════════
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Generic / regional gateways (Paymob, Tap, etc.) — rename to match your provider
PAYMENT_API_KEY=
PAYMENT_API_SECRET=
PAYMENT_HMAC_SECRET=

# PaySky OMNI — Notification Services (webhook POST /api/payments/paysky/notification)
# Webhook URL is NOT a secret — set one of these so it appears in .env and matches PaySky dashboard:
# 1) Full URL (recommended copy/paste for PaySky):
#PAYSKY_WEBHOOK_URL=https://YOUR_PUBLIC_API_HOST/api/payments/paysky/notification
# 2) Or public API origin only (no trailing slash); path /api/payments/paysky/notification is appended:
#PAYSKY_PUBLIC_API_BASE_URL=https://YOUR_PUBLIC_API_HOST
PAYSKY_WEBHOOK_URL=
PAYSKY_PUBLIC_API_BASE_URL=
# Optional: set to 1 to create admin notifications for failed HMAC / merchant / terminal checks (can be noisy).
PAYSKY_NOTIFY_AUTH_FAILURES=
# Set to 1 to allow POST /api/payments/paysky/simulate-trip-payment (and mobile rider simulate) when NODE_ENV=production.
PAYSKY_SIMULATE_TRIP_PAYMENT=
# Secret: hex string from PaySky (used as HMAC key after hex decode). Appendix A.
PAYSKY_SECRET_KEY_HEX=
# Optional: reject callbacks if ids do not match (recommended in production)
PAYSKY_MERCHANT_ID=
PAYSKY_TERMINAL_ID=
# ISO 4217 numeric currency code as sent by PaySky (e.g. 818 = EGP). Optional check.
PAYSKY_MERCHANT_CURRENCY_NUMERIC=
# Smallest-currency-units divisor for Amount field (e.g. 100 for EGP piastres)
PAYSKY_AMOUNT_MINOR_DIVISOR=100

# ─── MQTT (optional) ────────────────────────────────────
# MQTT_HOST=
# MQTT_PORT=1883
# MQTT_CLIENT_ID=
# MQTT_USERNAME=
# MQTT_PASSWORD=
# MQTT_UNIQUE_TOPIC_NAME=
# MQTT_CLEAN_SESSION=true

# ─── Firebase Push Notifications (optional) ──────────────
# FIREBASE_SERVICE_ACCOUNT=
# FIREBASE_CREDENTIALS_PATH=

# ─── OneSignal Push (optional) ───────────────────────────
# ONESIGNAL_APP_ID=
# ONESIGNAL_REST_API_KEY=
# DRIVER_APP_ID=
# DRIVER_REST_API_KEY=

# ─── Dedicated Booking (optional) ───────────────────────
# DEDICATED_BOOKING_CURRENCY=EGP
# DEDICATED_BOOKING_TAX_RATE=0.14
# DEDICATED_CANCELLATION_FULL_REFUND_HOURS=24
# DEDICATED_CANCELLATION_HALF_CHARGE_HOURS=12
