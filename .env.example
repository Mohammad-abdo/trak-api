# ─── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────
DATABASE_URL=mysql://root:@localhost:3306/driverproject

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# ─── CORS ────────────────────────────────────────────────
CORS_ORIGIN="*"
FRONTEND_URL=http://localhost:3000

# ─── Google Maps ─────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─── SMS (set SMS_DISABLED=true for dev to skip real SMS) ─
SMS_DISABLED=true
TEST_OTP=123456

# ─── MQTT (optional) ────────────────────────────────────
# MQTT_HOST=
# MQTT_PORT=1883
# MQTT_CLIENT_ID=
# MQTT_USERNAME=
# MQTT_PASSWORD=
# MQTT_UNIQUE_TOPIC_NAME=
# MQTT_CLEAN_SESSION=true

# ─── Firebase Push Notifications (optional) ──────────────
# FIREBASE_SERVICE_ACCOUNT=
# FIREBASE_CREDENTIALS_PATH=

# ─── OneSignal Push (optional) ───────────────────────────
# ONESIGNAL_APP_ID=
# ONESIGNAL_REST_API_KEY=
# DRIVER_APP_ID=
# DRIVER_REST_API_KEY=

# ─── Stripe (optional) ──────────────────────────────────
# STRIPE_SECRET_KEY=

# ─── Dedicated Booking (optional) ───────────────────────
# DEDICATED_BOOKING_CURRENCY=EGP
# DEDICATED_BOOKING_TAX_RATE=0.14
# DEDICATED_CANCELLATION_FULL_REFUND_HOURS=24
# DEDICATED_CANCELLATION_HALF_CHARGE_HOURS=12
